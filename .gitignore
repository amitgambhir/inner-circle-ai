# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Environment
.env
.env.local

# API keys — never commit these
*.key
*.secret

# Logs
*.log

# Temporary files
tmp/
temp/

# Python
__pycache__/
*.pyc
.pytest_cache/

# Claude Code
.claude/

# Superpowers working docs (specs and plans are committed separately)
docs/superpowers/

# Bot runtime state
.escalations-seen

# Agent runtime output — never commit these
agents/*/memory/*.md
!agents/*/memory/.gitkeep
projects/*/intel/**/*.md
projects/*/intel/**/*.json
!projects/*/intel/**/.gitkeep
projects/*/outbox/**/*.md
!projects/*/outbox/**/.gitkeep
projects/*/approved/*.md
!projects/*/approved/.gitkeep
projects/*/feedback/*.md
!projects/*/feedback/.gitkeep
projects/*/escalations/*.md
!projects/*/escalations/.gitkeep
projects/*/content/**/*.md
!projects/*/content/**/.gitkeep
